# Copie este arquivo para .env e preencha os valores

# URL de conexão do banco PostgreSQL (gerada automaticamente pelo Railway)
DATABASE_URL=postgresql://usuario:senha@host:5432/banco

# Chave secreta para JWT — gere uma string aleatória longa
JWT_SECRET=troque-por-uma-chave-secreta-longa-e-aleatoria

# URL do frontend (para o CORS)
FRONTEND_URL=https://seu-app.vercel.app

# Ambiente
NODE_ENV=production

# Porta (Railway define automaticamente)
PORT=3001
